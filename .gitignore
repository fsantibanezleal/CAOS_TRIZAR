# Minimal-but-complete ignore for an instantiated product repo (ADR-0057).

# --- Python virtualenvs (ANY name, ANY depth) — NEVER committed; recreate via scripts/setup ---
.venv/
.venv*
**/.venv*
venv/
**/venv/

# --- Python caches / build ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
build/
dist/

# --- Node / web ---
node_modules/
frontend/dist/
frontend/.vite/
.vite
*.local
# build-time overlay generated by frontend/copy-data.mjs (canonical copies live in data/derived)
frontend/public/data/
frontend/public/surrogate.onnx
frontend/public/surrogate.int8.onnx
frontend/public/psd-ae.onnx
frontend/public/scaler.json
frontend/public/ae_scaler.json
frontend/public/ae_threshold.json
frontend/public/surrogate_metrics.json
*.tsbuildinfo

# --- the offline sweep datasets (the surrogate's training labels) — regenerable, never committed ---
data-pipeline/chancalab/sweep/*.jsonl
# raw offline DEM solver exports — NEVER a web payload
data/raw/
**/*.vtk
**/*.vtu

# --- Secrets / env (public repo — only .env.example is committed) ---
.env
.env.*
!.env.example

# --- Raw / heavy data — commit ONLY the compact derived artifacts under data/derived/ ---
*.parquet
*.h5
*.hdf5
*.nc
*.npy
models/*.pt
models/*.pth
*.dll
*.so
*.dylib

# --- OS / logs ---
.DS_Store
Thumbs.db
*.log
